{
  "version": 1,
  "change_types": {
    "commands_workflow": {
      "match_paths": [
        "Makefile",
        "README.md",
        "docs/runbooks/local-development.md",
        ".pre-commit-config.yaml",
        ".github/workflows/*.yml"
      ],
      "review_context": [
        "AGENTS.md",
        "apps/api/AGENTS.md",
        "apps/web/AGENTS.md"
      ],
      "update_docs": [
        "README.md",
        "docs/runbooks/local-development.md"
      ],
      "run_checks": [
        "docs-check"
      ]
    },
    "runtime_security_deploy": {
      "match_paths": [
        ".env.example",
        "infra/compose/*.yaml",
        "infra/docker/*",
        "apps/api/src/app/core/settings.py",
        "apps/api/src/app/core/http.py",
        "apps/api/src/app/main.py",
        "apps/web/next.config.js"
      ],
      "review_context": [
        "AGENTS.md",
        "SECURITY.md"
      ],
      "update_docs": [
        "SECURITY.md",
        "docs/architecture/docker-and-runtime.md",
        ".env.example"
      ],
      "run_checks": [
        "docs-check",
        "ci"
      ]
    },
    "repo_structure": {
      "match_paths": [
        "apps",
        "apps/**",
        "docs/architecture/repository-structure.md"
      ],
      "review_context": [
        "AGENTS.md"
      ],
      "update_docs": [
        "docs/architecture/repository-structure.md",
        "docs/adr"
      ],
      "run_checks": [
        "docs-check"
      ]
    },
    "api_contract": {
      "match_paths": [
        "apps/api/src/app/modules/**/api/*.py",
        "apps/api/src/app/modules/**/application/*.py",
        "apps/api/tests/**/*.py",
        "apps/web/src/lib/**/*",
        "apps/web/src/app/**/*",
        "apps/web/src/components/**/*",
        "apps/web/src/features/**/*"
      ],
      "review_context": [
        "apps/api/AGENTS.md",
        "apps/web/AGENTS.md"
      ],
      "update_docs": [],
      "run_checks": [
        "api-typecheck",
        "api-test",
        "web-typecheck",
        "web-test"
      ]
    },
    "data_model_schema": {
      "match_paths": [
        "apps/api/migrations/**/*",
        "apps/api/src/app/db/**/*",
        "apps/api/src/app/modules/**/infrastructure/*.py",
        "docs/runbooks/database-migrations.md"
      ],
      "review_context": [
        "apps/api/AGENTS.md",
        "docs/runbooks/database-migrations.md"
      ],
      "update_docs": [
        "docs/runbooks/database-migrations.md"
      ],
      "run_checks": [
        "api-test",
        "docs-check"
      ]
    },
    "agent_workflow": {
      "match_paths": [
        "AGENTS.md",
        "apps/api/AGENTS.md",
        "apps/web/AGENTS.md",
        "CONTRIBUTING.md",
        "docs/change-impact.json",
        "scripts/docs_check.py",
        "scripts/docs_suggest.py"
      ],
      "review_context": [
        "AGENTS.md",
        "CONTRIBUTING.md"
      ],
      "update_docs": [
        "AGENTS.md",
        "apps/api/AGENTS.md",
        "apps/web/AGENTS.md",
        "CONTRIBUTING.md"
      ],
      "run_checks": [
        "docs-check"
      ]
    },
    "auth_shared_runtime_config": {
      "scope": "cross_app",
      "match_paths": [
        ".env.example",
        "apps/api/src/app/core/settings.py",
        "apps/api/src/app/main.py",
        "apps/web/src/lib/**/*",
        "apps/web/src/app/**/*"
      ],
      "review_context": [
        "apps/api/AGENTS.md",
        "apps/web/AGENTS.md",
        "SECURITY.md"
      ],
      "update_docs": [
        "SECURITY.md",
        "docs/architecture/docker-and-runtime.md"
      ],
      "run_checks": [
        "api-typecheck",
        "api-test",
        "web-typecheck",
        "web-test",
        "docs-check"
      ]
    },
    "browser_exposed_envs": {
      "scope": "cross_app",
      "match_paths": [
        ".env.example",
        "apps/web/src/lib/**/*",
        "apps/web/src/app/**/*",
        "apps/web/next.config.js"
      ],
      "review_context": [
        "apps/web/AGENTS.md",
        "SECURITY.md"
      ],
      "update_docs": [
        "SECURITY.md",
        ".env.example"
      ],
      "run_checks": [
        "web-typecheck",
        "web-test",
        "docs-check"
      ]
    }
  }
}
